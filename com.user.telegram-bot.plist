<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.telegram-bot</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-l</string>
        <string>-c</string>
        <string>export $(cat __HOME__/.config/telegram-bot/.env | xargs); exec "$(which node)" --import tsx/esm __INSTALL_DIR__/src/bot.ts</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/telegram-bot/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/telegram-bot/stderr.log</string>
    <key>WorkingDirectory</key>
    <string>__INSTALL_DIR__</string>
</dict>
</plist>
